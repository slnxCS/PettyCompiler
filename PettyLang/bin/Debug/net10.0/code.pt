# Третья функция: проверяем локальные переменные
func Third(a : int32) : int32 {
    var temp = 100;
    return a + temp;
}

# Вторая функция: проверяем передачу двух аргументов
func Second(a : int32, b : int32) : int32 {
    var temp = 5;
    var res = Third(a + b);
    return res + temp;
}

# Первая функция: проверяем изоляцию кадра
func First(x : int32) : int32 {
    var temp = 10;
    return Second(temp, x); 
}

# Главная функция возвращает void
func Main() : void {
    var finalResult = First(5);
    print(finalResult); # На выходе в консоли должно быть ровно 120
}