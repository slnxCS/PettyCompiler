var minusZero : int32 = -1;

func test(a : int32, b : int32, c : int32) : int32 {
    var d = 10 * minusZero - -10;
    print(d);
    var e = a - b - c - d;
    print(e);
    return e + 100;
}

func Main() : {
    var y = 15.9;
    var x : int32 = y as int32;
    print(x);
    print(test(10,20,30));
}